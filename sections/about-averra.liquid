{% comment %}
  About AVERRA Section
{% endcomment %}

{%- style -%}
  .about-averra {
    padding: 120px 40px;
    background-color: white;
  }

  .about-averra__container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .about-averra__image-container {
    width: 100%;
    height: 600px;
    overflow: hidden;
    border-radius: 2px;
  }

  .about-averra__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-averra__content {
    padding: 40px 0;
  }

  .about-averra__eyebrow {
    font-family: var(--font-heading-family);
    font-size: 14px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #8B7355;
    margin-bottom: 24px;
    font-weight: 500;
  }

  .about-averra__title {
    font-family: var(--font-heading-family);
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.2;
    color: #2C2420;
    margin: 0 0 32px 0;
    font-weight: 400;
  }

  .about-averra__description {
    font-size: 18px;
    line-height: 1.8;
    color: #5C5855;
    margin-bottom: 32px;
  }

  .about-averra__features {
    list-style: none;
    padding: 0;
    margin: 0 0 40px 0;
  }

  .about-averra__feature {
    font-size: 16px;
    color: #2C2420;
    padding: 16px 0;
    border-bottom: 1px solid #F5F1ED;
    display: flex;
    align-items: flex-start;
  }

  .about-averra__feature::before {
    content: "✓";
    color: #8B7355;
    font-weight: bold;
    font-size: 20px;
    margin-right: 16px;
    flex-shrink: 0;
  }

  .about-averra__button {
    padding: 18px 48px;
    background-color: #2C2420;
    color: #F5F1ED;
    text-decoration: none;
    font-size: 14px;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: all 0.3s ease;
    display: inline-block;
    border: none;
    cursor: pointer;
    font-family: var(--font-heading-family);
    font-weight: 500;
  }

  .about-averra__button:hover {
    background-color: #8B7355;
  }

  @media (max-width: 968px) {
    .about-averra {
      padding: 80px 24px;
    }

    .about-averra__container {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .about-averra__image-container {
      height: 400px;
    }
  }
{%- endstyle -%}

<section class="about-averra">
  <div class="about-averra__container">
    {% if section.settings.image_position == 'left' %}
      <div class="about-averra__image-container">
        {% if section.settings.image != blank %}
          <img 
            src="{{ section.settings.image | image_url: width: 800 }}" 
            alt="{{ section.settings.image.alt | escape }}"
            class="about-averra__image"
            loading="lazy"
          >
        {% else %}
          <div class="about-averra__image" style="background: linear-gradient(135deg, #8B7355 0%, #C9BFB5 100%);"></div>
        {% endif %}
      </div>
    {% endif %}

    <div class="about-averra__content">
      {% if section.settings.eyebrow != blank %}
        <p class="about-averra__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.title != blank %}
        <h2 class="about-averra__title">{{ section.settings.title }}</h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="about-averra__description">
          {{ section.settings.description }}
        </div>
      {% endif %}

      {% if section.settings.features != blank %}
        <ul class="about-averra__features">
          {% assign features = section.settings.features | split: '|' %}
          {% for feature in features %}
            <li class="about-averra__feature">{{ feature }}</li>
          {% endfor %}
        </ul>
      {% endif %}

      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="about-averra__button">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>

    {% if section.settings.image_position == 'right' %}
      <div class="about-averra__image-container">
        {% if section.settings.image != blank %}
          <img 
            src="{{ section.settings.image | image_url: width: 800 }}" 
            alt="{{ section.settings.image.alt | escape }}"
            class="about-averra__image"
            loading="lazy"
          >
        {% else %}
          <div class="about-averra__image" style="background: linear-gradient(135deg, #8B7355 0%, #C9BFB5 100%);"></div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "About AVERRA",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "ABOUT AVERRA"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Section Title",
      "default": "Elevate Your Beauty Business"
    },
    {
      "type": "html",
      "id": "description",
      "label": "Description",
      "default": "<p>We understand the journey from hustle to high-end. Our luxury branding solutions are crafted specifically for beauty professionals who are ready to transition from chasing clients to attracting dream clientele.</p><p>With AVERRA, you'll command premium rates and build a lasting legacy in the beauty industry.</p>"
    },
    {
      "type": "textarea",
      "id": "features",
      "label": "Features (separate with |)",
      "default": "Tailored specifically for beauty professionals|High-end editorial aesthetic|Premium branding that attracts dream clients|Complete brand transformation packages",
      "info": "Use | to separate each feature"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/pages/about"
    }
  ],
  "presets": [
    {
      "name": "About AVERRA"
    }
  ]
}
{% endschema %}
