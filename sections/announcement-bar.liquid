{% comment %}
  Announcement Bar
{% endcomment %}

{%- style -%}
  .announcement-bar {
    background: linear-gradient(135deg, #8B7355 0%, #A0866F 100%);
    color: white;
    padding: 12px 20px;
    text-align: center;
    font-size: 14px;
    letter-spacing: 0.5px;
    position: relative;
    overflow: hidden;
  }

  .announcement-bar::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
    animation: shine 3s infinite;
  }

  @keyframes shine {
    0% {
      left: -100%;
    }
    100% {
      left: 100%;
    }
  }

  .announcement-bar__content {
    position: relative;
    z-index: 1;
  }

  .announcement-bar__link {
    color: white;
    text-decoration: underline;
    font-weight: 600;
    margin-left: 8px;
  }

  .announcement-bar__link:hover {
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .announcement-bar {
      font-size: 12px;
      padding: 10px 16px;
    }
  }
{%- endstyle -%}

{% if section.settings.show_announcement %}
  <div class="announcement-bar">
    <div class="announcement-bar__content">
      {{ section.settings.announcement_text }}
      {% if section.settings.show_link and section.settings.link_text != blank %}
        <a href="{{ section.settings.link_url }}" class="announcement-bar__link">
          {{ section.settings.link_text }}
        </a>
      {% endif %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show Announcement Bar",
      "default": true
    },
    {
      "type": "textarea",
      "id": "announcement_text",
      "label": "Announcement Text",
      "default": "✨ Founding Member Pricing: Save up to 60% | Offer ends May 31st, 2026"
    },
    {
      "type": "checkbox",
      "id": "show_link",
      "label": "Show Link",
      "default": true
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text",
      "default": "Claim Your Discount"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL",
      "default": "/pages/services"
    }
  ]
}
{% endschema %}
