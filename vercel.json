{
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@3.2.21",
      "includeFiles": "api/**"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}