{% comment %}
  AVERRA Footer
{% endcomment %}

<footer class="averra-footer" id="footer-{{ section.id }}">
  <div class="footer-main page-width">
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-column footer-brand">
        <h3 class="footer-logo">{{ section.settings.footer_logo_text | default: shop.name }}</h3>
        <p class="footer-tagline">{{ section.settings.tagline }}</p>
        
        {% if section.settings.show_social %}
          <div class="footer-social">
            {% if section.settings.social_instagram %}
              <a href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke="currentColor" stroke-width="2" fill="none"></rect>
                  <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2" fill="none"></circle>
                  <circle cx="18" cy="6" r="1.5" fill="currentColor"></circle>
                </svg>
              </a>
            {% endif %}
            
            {% if section.settings.social_facebook %}
              <a href="{{ section.settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
                </svg>
              </a>
            {% endif %}
            
            {% if section.settings.social_twitter %}
              <a href="{{ section.settings.social_twitter }}" target="_blank" rel="noopener" aria-label="Twitter">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
                </svg>
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>

      <!-- Quick Links -->
      {% for block in section.blocks %}
        {% if block.type == 'link_list' %}
          <div class="footer-column">
            <h4 class="footer-heading">{{ block.settings.heading }}</h4>
            <ul class="footer-links">
              {% for link in linklists[block.settings.menu].links %}
                <li>
                  <a href="{{ link.url }}" class="footer-link">{{ link.title }}</a>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      {% endfor %}

      <!-- Newsletter -->
      {% if section.settings.show_newsletter %}
        <div class="footer-column footer-newsletter">
          <h4 class="footer-heading">{{ section.settings.newsletter_heading }}</h4>
          <p class="newsletter-text">{{ section.settings.newsletter_text }}</p>
          
          {% form 'customer', class: 'newsletter-form' %}
            {% if form.posted_successfully? %}
              <p class="form-success">{{ section.settings.newsletter_success_message }}</p>
            {% endif %}
            
            <div class="newsletter-input-wrapper">
              <input
                type="email"
                name="contact[email]"
                class="newsletter-input"
                placeholder="{{ section.settings.newsletter_placeholder }}"
                required
              >
              <button type="submit" class="newsletter-submit">
                Subscribe
              </button>
            </div>
          {% endform %}
        </div>
      {% endif %}
    </div>
  </div>

  <!-- Footer Bottom -->
  <div class="footer-bottom">
    <div class="footer-bottom-inner page-width">
      <p class="footer-copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_text }}
      </p>
      
      <div class="footer-payment-icons">
        {% if section.settings.show_payment_icons %}
          <span class="payment-label">We accept:</span>
          <div class="payment-icons">
            <svg width="40" height="25" viewBox="0 0 40 25" fill="none">
              <rect width="40" height="25" rx="3" fill="#1434CB"/>
              <text x="50%" y="50%" text-anchor="middle" dominant-baseline="middle" fill="white" font-size="10" font-weight="bold">VISA</text>
            </svg>
            <svg width="40" height="25" viewBox="0 0 40 25" fill="none">
              <rect width="40" height="25" rx="3" fill="#EB001B"/>
              <circle cx="15" cy="12.5" r="8" fill="#FF5F00" opacity="0.8"/>
              <circle cx="25" cy="12.5" r="8" fill="#F79E1B" opacity="0.8"/>
            </svg>
            <svg width="40" height="25" viewBox="0 0 40 25" fill="none">
              <rect width="40" height="25" rx="3" fill="#635BFF"/>
            </svg>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

<style>
  .averra-footer {
    background-color: #1a0f0d;
    color: rgba(255, 255, 255, 0.8);
    padding: 6rem 0 0;
    margin-top: 8rem;
    border-top: 1px solid rgba(220, 218, 204, 0.1);
  }

  .footer-main {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 2rem 4rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 4rem;
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr repeat(3, 1fr);
      gap: 5rem;
    }
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #DCDACC;
    text-transform: uppercase;
    margin: 0;
  }

  .footer-tagline {
    font-family: 'Cormorant', serif;
    font-size: 1.125rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    max-width: 30rem;
  }

  .footer-social {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .footer-social a {
    color: #DCDACC;
    transition: opacity 0.3s ease;
  }

  .footer-social a:hover {
    opacity: 0.7;
  }

  .footer-heading {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #DCDACC;
    margin: 0 0 1rem 0;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-link {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.3s ease;
  }

  .footer-link:hover {
    color: #DCDACC;
  }

  .newsletter-text {
    font-size: 0.875rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
  }

  .newsletter-form {
    margin-top: 1rem;
  }

  .form-success {
    color: #4ade80;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  .newsletter-input-wrapper {
    display: flex;
    gap: 0.5rem;
  }

  .newsletter-input {
    flex: 1;
    padding: 0.75rem 1rem;
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(220, 218, 204, 0.2);
    color: white;
    font-size: 0.875rem;
  }

  .newsletter-input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  .newsletter-submit {
    padding: 0.75rem 1.5rem;
    background-color: #DCDACC;
    color: #301710;
    border: none;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .newsletter-submit:hover {
    background-color: #BFBBA7;
  }

  .footer-bottom {
    background-color: rgba(0, 0, 0, 0.3);
    border-top: 1px solid rgba(220, 218, 204, 0.1);
    padding: 2rem 0;
  }

  .footer-bottom-inner {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
    justify-content: space-between;
  }

  @media (min-width: 768px) {
    .footer-bottom-inner {
      flex-direction: row;
    }
  }

  .footer-copyright {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
  }

  .footer-payment-icons {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .payment-label {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .payment-icons {
    display: flex;
    gap: 0.5rem;
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "footer_logo_text",
      "label": "Logo Text",
      "default": "AVERRA"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Luxury AI branding for beauty professionals"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Links",
      "default": true
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "Twitter URL"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show Newsletter Signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "Stay Connected"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter Text",
      "default": "Get exclusive branding tips and special offers"
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email Placeholder",
      "default": "Your email"
    },
    {
      "type": "text",
      "id": "newsletter_success_message",
      "label": "Success Message",
      "default": "Thanks for subscribing!"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "All rights reserved."
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "heading": "Quick Links",
          "menu": "footer"
        }
      }
    ]
  }
}
{% endschema %}
