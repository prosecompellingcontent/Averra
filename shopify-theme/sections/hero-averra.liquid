{% comment %}
  AVERRA Hero Section
  Full-screen hero with background image and CTA
{% endcomment %}

<section class="averra-hero" id="hero-section-{{ section.id }}">
  <div class="hero-background">
    {% if section.settings.hero_image %}
      <img
        src="{{ section.settings.hero_image | image_url: width: 1920 }}"
        srcset="
          {{ section.settings.hero_image | image_url: width: 768 }} 768w,
          {{ section.settings.hero_image | image_url: width: 1200 }} 1200w,
          {{ section.settings.hero_image | image_url: width: 1920 }} 1920w
        "
        sizes="100vw"
        alt="{{ section.settings.hero_image.alt | escape }}"
        class="hero-bg-image"
        loading="eager"
      >
    {% else %}
      <div class="hero-bg-fallback"></div>
    {% endif %}
    <div class="hero-overlay"></div>
  </div>

  <!-- Large watermark text -->
  <div class="hero-watermark">
    <h2 class="watermark-text">{{ section.settings.watermark_text | default: 'AVERRA' }}</h2>
  </div>

  <!-- Main hero content -->
  <div class="hero-content">
    <div class="hero-text-wrapper">
      <div class="hero-text-content">
        <p class="hero-title">
          {{ section.settings.hero_title | default: "Beauty's New Blueprint" }}
        </p>
        <p class="hero-subtitle">
          {{ section.settings.hero_subtitle | default: "Hesitation Is Expensive." }}
        </p>
      </div>

      <div class="hero-cta-wrapper">
        {% if section.settings.cta_url != blank %}
          <a href="{{ section.settings.cta_url }}" class="hero-cta-button">
            {{ section.settings.cta_text | default: "Start Your Brand Quiz" }}
          </a>
        {% endif %}

        <p class="hero-tagline">
          {{ section.settings.tagline | default: "No Shoots. No Designers. No Stress." }}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .averra-hero {
    position: relative;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    background-color: #2d1810;
  }

  .hero-bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-bg-fallback {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #2d1810 0%, #4A2E1F 100%);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.5),
      rgba(0, 0, 0, 0.3),
      rgba(0, 0, 0, 0.4)
    );
  }

  .hero-watermark {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 5;
  }

  .watermark-text {
    white-space: nowrap;
    color: rgba(255, 255, 255, 0.1);
    user-select: none;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: clamp(6rem, 14vw, 14rem);
  }

  .hero-content {
    position: relative;
    max-width: 48rem;
    margin: 0 auto;
    z-index: 10;
    padding: 0 2rem;
    margin-top: 11rem;
  }

  @media (min-width: 768px) {
    .hero-content {
      margin-top: 7.75rem;
    }
  }

  .hero-text-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .hero-text-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  @media (min-width: 768px) {
    .hero-text-content {
      margin-bottom: 1.5rem;
    }
  }

  .hero-title {
    line-height: 1.3;
    color: rgba(255, 255, 255, 0.95);
    text-align: center;
    font-family: 'Cormorant', serif;
    font-weight: 400;
    font-size: clamp(1.75rem, 6vw, 3.75rem);
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 2.25rem;
    }
  }

  @media (min-width: 1280px) {
    .hero-title {
      font-size: 3rem;
    }
  }

  @media (min-width: 1536px) {
    .hero-title {
      font-size: 3.75rem;
    }
  }

  .hero-subtitle {
    color: rgba(255, 255, 255, 0.8);
    letter-spacing: 0.05em;
    text-align: center;
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
  }

  @media (min-width: 768px) {
    .hero-subtitle {
      font-size: 1.25rem;
    }
  }

  @media (min-width: 1280px) {
    .hero-subtitle {
      font-size: 1.5rem;
    }
  }

  .hero-cta-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: center;
    margin-top: 2rem;
  }

  @media (min-width: 768px) {
    .hero-cta-wrapper {
      margin-top: 0;
    }
  }

  .hero-cta-button {
    display: inline-block;
    padding: 1rem 3rem;
    background-color: #DCDACC;
    color: #301710;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    transition: background-color 0.3s ease;
    text-decoration: none;
  }

  .hero-cta-button:hover {
    background-color: #BFBBA7;
  }

  @media (max-width: 768px) {
    .hero-cta-button:hover {
      background-color: #DCDACC;
    }
  }

  .hero-tagline {
    color: rgba(255, 255, 255, 0.8);
    letter-spacing: 0.05em;
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
  }

  @media (min-width: 768px) {
    .hero-tagline {
      font-size: 1.25rem;
    }
  }

  @media (min-width: 1280px) {
    .hero-tagline {
      font-size: 1.5rem;
    }
  }
</style>

{% schema %}
{
  "name": "Hero AVERRA",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image",
      "info": "Recommended size: 1920x1080px"
    },
    {
      "type": "text",
      "id": "watermark_text",
      "label": "Watermark Text",
      "default": "AVERRA"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero Title",
      "default": "Beauty's New Blueprint"
    },
    {
      "type": "text",
      "id": "hero_subtitle",
      "label": "Hero Subtitle",
      "default": "Hesitation Is Expensive."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Start Your Brand Quiz"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Button URL",
      "default": "/pages/quiz"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "No Shoots. No Designers. No Stress."
    }
  ],
  "presets": [
    {
      "name": "Hero AVERRA"
    }
  ]
}
{% endschema %}
