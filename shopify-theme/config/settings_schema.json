[
  {
    "name": "theme_info",
    "theme_name": "AVERRA AI Model Studio",
    "theme_version": "1.0.0",
    "theme_author": "AVERRA",
    "theme_documentation_url": "https://averra.ai/docs",
    "theme_support_url": "https://averra.ai/support"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Brand Colors"
      },
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary Color",
        "default": "#DCDACC"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Secondary Color",
        "default": "#301710"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent Color",
        "default": "#BFBBA7"
      },
      {
        "type": "header",
        "content": "Background Colors"
      },
      {
        "type": "color",
        "id": "color_background_1",
        "label": "Background Color 1",
        "default": "#221412"
      },
      {
        "type": "color",
        "id": "color_background_2",
        "label": "Background Color 2",
        "default": "#2d1810"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Heading Font"
      },
      {
        "type": "font_picker",
        "id": "type_header_font",
        "default": "assistant_n4",
        "label": "Font",
        "info": "Default: Cormorant Garamond"
      },
      {
        "type": "range",
        "id": "heading_scale",
        "min": 100,
        "max": 150,
        "step": 5,
        "unit": "%",
        "label": "Heading Scale",
        "default": 100
      },
      {
        "type": "header",
        "content": "Body Font"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "assistant_n4",
        "label": "Font",
        "info": "Default: Cormorant"
      },
      {
        "type": "range",
        "id": "body_scale",
        "min": 100,
        "max": 130,
        "step": 5,
        "unit": "%",
        "label": "Body Scale",
        "default": 100
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "32 x 32px .png recommended"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart Type",
        "default": "page",
        "options": [
          {
            "value": "page",
            "label": "Page"
          },
          {
            "value": "drawer",
            "label": "Drawer"
          }
        ]
      },
      {
        "type": "checkbox",
        "id": "cart_notes_enable",
        "label": "Enable Cart Notes",
        "default": false
      }
    ]
  },
  {
    "name": "Product Grid",
    "settings": [
      {
        "type": "range",
        "id": "products_per_row",
        "min": 2,
        "max": 4,
        "step": 1,
        "label": "Products per Row (Desktop)",
        "default": 3
      },
      {
        "type": "checkbox",
        "id": "show_vendor",
        "label": "Show Vendor",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "show_quick_add",
        "label": "Enable Quick Add Button",
        "default": true
      }
    ]
  },
  {
    "name": "Stripe Integration",
    "settings": [
      {
        "type": "header",
        "content": "Stripe Configuration"
      },
      {
        "type": "paragraph",
        "content": "Enter your Stripe API keys to enable custom checkout. Get your keys from https://dashboard.stripe.com/apikeys"
      },
      {
        "type": "text",
        "id": "stripe_publishable_key",
        "label": "Stripe Publishable Key",
        "info": "Starts with pk_"
      },
      {
        "type": "text",
        "id": "stripe_secret_key",
        "label": "Stripe Secret Key (Backend)",
        "info": "Starts with sk_ - This should be kept private"
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "header",
        "content": "Social Media Links"
      },
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "Facebook URL"
      },
      {
        "type": "text",
        "id": "social_twitter_link",
        "label": "Twitter URL"
      },
      {
        "type": "text",
        "id": "social_pinterest_link",
        "label": "Pinterest URL"
      },
      {
        "type": "text",
        "id": "social_tiktok_link",
        "label": "TikTok URL"
      }
    ]
  }
]
